# Copy this to .env.staging and fill in the values before deploying.
# NEVER commit the filled-in .env.staging to git.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=gamexs
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=gamexs

# Must use the docker-compose service name "db" as the host (not localhost).
DATABASE_URL=postgresql://gamexs:change_me_strong_password@db:5432/gamexs

# ── Frontend ──────────────────────────────────────────────────────────────────
# Port exposed on the host machine (put a reverse proxy in front in production)
FRONTEND_PORT=3000

# ── IGDB metadata enrichment (scraper) ────────────────────────────────────────
# Create a free Twitch app at https://dev.twitch.tv/console/apps
# Category: "Other" — any redirect URI works (e.g. http://localhost)
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
