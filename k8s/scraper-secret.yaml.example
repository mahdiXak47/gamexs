# Copy to scraper-secret.yaml, fill in real values, then apply:
#   kubectl apply -f k8s/scraper-secret.yaml
#
# NEVER commit scraper-secret.yaml to git — it contains real credentials.
# .gitignore already excludes *-secret.yaml.

apiVersion: v1
kind: Secret
metadata:
  name: gamexs-scraper-secret
  namespace: mahdixak-gamexs
type: Opaque
stringData:
  DATABASE_URL: "postgresql://gamexs:gamexs@gamexs-db.mahdixak-gamexs.svc:5432/gamexs"
  HTTPS_PROXY: "http://USER:PASS@conn.hamravesh.ir:8080"
  IGDB_CLIENT_ID: "2qsedq5y7o8w7wq1o0ivmhuhabwg8u"
  IGDB_CLIENT_SECRET: "YOUR_IGDB_CLIENT_SECRET"
