# Copy to .env.local for local development (Docker container at port 5434).
# In production (Kubernetes), set DATABASE_URL as a Secret env var.
#
# Local dev:
DATABASE_URL=postgresql://gamexs:gamexs@localhost:5434/gamexs
#
# Production (k8s svc):
# DATABASE_URL=postgresql://gamexs:gamexs@gamexs-db.mahdixak-gamexs.svc:5432/gamexs
